<!doctype html>
<html lang="en">
  <%- include("partials/_head") %>
  <body>
    <%- include("partials/_header") %>
    <!-- // Main content of the home page & need better UI -->
    <main class="p-4 text-center bg-gray-100 flex flex-col items-center justify-center ">
      <h1 class="text-3xl font-bold mb-4">Welcome to Airbnb</h1>
      <p class="text-lg mb-6">Discover and book unique homes around the world.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% homes.forEach(home => { %>
          <div class="bg-white p-4 rounded shadow">
            <img
              class="w-full h-48 object-cover rounded mb-4"
              src="<%= home.image %>"
              alt="<%= home.name %>"
            />
            <h2 class="text-xl font-semibold mb-2"><%= home.name %></h2>
            <p class="text-gray-600 mb-1">Location: <%= home.address %></p>
            <p class="text-gray-600 mb-1">Price per Night: $<%= home.price %></p>
          </div>
        <% }) %>
      </div>
  </body>
</html>
