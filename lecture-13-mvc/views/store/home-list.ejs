<!doctype html>
<html lang="en">
  <%- include("../partials/_head") %>
  <body>
    <%- include("../partials/_header") %>
    <!-- // Main content of the home page & need better UI -->
    <main class="p-4 text-center bg-gray-100 flex flex-col items-center justify-center ">
      <h1 class="text-3xl font-bold mb-4">Welcome to Airbnb</h1>
      <p class="text-lg mb-6">Discover and book unique homes around the world.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% homes.forEach(home => { %>
          <div class="bg-white p-4 rounded shadow">
            <!-- //favourite icon -->
            <button class="text-red-500 hover:text-red-700 cursor-pointer hover:scale-110 transition-transform absolute top-2 right-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" width="24" height="24">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </button>
            <img
              class="w-full h-48 object-cover rounded mb-4"
              src="<%= home.image %>"
              alt="<%= home.name %>"
            />
            <h2 class="text-xl font-semibold mb-2"><%= home.name %></h2>
            <p class="text-gray-600 mb-1">Location: <%= home.address %></p>
            <p class="text-gray-600 mb-1">Price per Night: $<%= home.price %></p>
            <button class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
              Book Now
            </button>
          </div>
        <% }) %>
      </div>
  </body>
</html>
