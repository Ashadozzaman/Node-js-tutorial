<!doctype html>
<html lang="en">
  <%- include("../partials/_head") %>
  <body>
    <%- include("../partials/_header") %>
    <!-- Sinup page design here -->
    <main
      class="p-4 text-center bg-gray-100 flex flex-col items-center justify-center gap-4 mx-auto mt-10 rounded-lg w-[50%]"
    >
      <h1 class="text-3xl font-bold mb-4">Signup Page</h1>
      <p class="text-lg mb-6">This is the Signup page.</p>

      <form
        action="/signup"
        method="POST"
        class="flex flex-col items-center gap-4 border border-gray-300 rounded-lg p-6 bg-white shadow-md"
      >
      <% if (errorMessage && errorMessage.length > 0) { %> 
        <% errorMessage.forEach((msg) => { %> 
          <div class="bg-red-100 text-red-700  rounded p-1  w-full"> 
              <strong><%= msg %></strong> 
          </div>
        <% }) %>
      <% } %>
        <input
          type="text"
          name="username"
          placeholder="Enter User Name"
          required
          class="border border-gray-300 rounded-lg p-2 w-64"
          value="<%= typeof oldInput !== 'undefined' ? oldInput.username : '' %>"
        />
        <input
          type="text"
          name="email"
          placeholder="Enter Email"
          required
          class="border border-gray-300 rounded-lg p-2 w-64"
          value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>"
        />
        <input
          type="text"
          name="number"
          placeholder="Enter Number"
          required
          class="border border-gray-300 rounded-lg p-2 w-64"
          value="<%= typeof oldInput !== 'undefined' ? oldInput.number : '' %>"
        />
        <select
          name="userType"
          class="border border-gray-300 rounded-lg p-2 w-64"
        >
          <option value="">Select User Type</option>
          <option value="host" <%= (typeof oldInput !== 'undefined' && oldInput.userType === 'host') ? 'selected' : '' %>>Host</option>
          <option value="store" <%= (typeof oldInput !== 'undefined' && oldInput.userType === 'store') ? 'selected' : '' %>>Store</option>
        </select>
        <input
          type="password"
          name="password"
          placeholder="Password"
          required
          class="border border-gray-300 rounded-lg p-2 w-64"
        />
        <input
          type="password"
          name="confirmPassword"
          placeholder="Confirm Password"
          required
          class="border border-gray-300 rounded-lg p-2 w-64"
        />
        <div class="flex items-center gap-2">
          <input 
          type="checkbox"
           name="terms" 
           required
            class="border border-gray-300 rounded-lg p-2" 
           />
          <label for="terms" class="text-sm text-gray-600">
            I agree to the terms and conditions
          </label>
        </div>

        <button
          type="submit"
          class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded"
        >
          Signup
        </button>
      </form>
    </main>
  </body>
</html>
